<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:aa_hw_6_UI.ViewModels"
        xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
        x:Class="aa_hw_6_UI.Views.MainWindow"
        Title="aa_hw_6_UI"
        Width="1100" Height="650"
        MinWidth="900" MinHeight="500"
        x:DataType="vm:MainWindowViewModel">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="350, *" Margin="15">
        
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="5 0 10 0">
            <StackPanel Grid.Column="0" Spacing="15">
                
                <Border BorderBrush="Navy" BorderThickness="1" Padding="15" CornerRadius="5">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Образующие идеала I" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="Введите мономы через запятую.&#x0a;Формат: x^6, x^2y^3, xy^7" 
                                   TextWrapping="Wrap" FontSize="12" Foreground="DarkGray"/>
                        
                        <TextBox Text="{Binding GeneratorsText}" 
                                 AcceptsReturn="True" 
                                 Height="100" 
                                 TextWrapping="Wrap"
                                 FontFamily="Consolas, Courier New, monospace"/>
                    </StackPanel>
                </Border>

                <Button Content="Построить график" Command="{Binding PlotCommand}" 
                        Padding="12" HorizontalAlignment="Stretch"
                        Background="LightGreen" FontWeight="DemiBold" 
                        HorizontalContentAlignment="Center"/>
                
                <Button Content="Открыть из файла" Command="{Binding LoadFromFileCommand}" 
                        Padding="12" HorizontalAlignment="Stretch"
                        Background="#CCCCFF"
                        HorizontalContentAlignment="Center"/>

                <Button Content="Сохранить в файл" Command="{Binding SaveToFileCommand}" 
                        Padding="12" HorizontalAlignment="Stretch"
                        Background="#E1BEE7"
                        HorizontalContentAlignment="Center"
                        Margin="0 -5 0 0"/>

                <Border Background="#F0F0F0" CornerRadius="5" Padding="15" Margin="0 15 0 0">
                    <StackPanel Spacing="5">
                        <TextBlock Text="Статус работы:" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        
        <Grid Grid.Column="1" Margin="10 0 0 0">
            <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" Padding="10">
                <lvc:CartesianChart Series="{Binding Series}"
                                    XAxes="{Binding XAxes}"
                                    YAxes="{Binding YAxes}"
                                    LegendPosition="Top"
                                    ZoomMode="Both"
                                    TooltipPosition="Hidden"/>
            </Border>
        </Grid>
        
    </Grid>
</Window>