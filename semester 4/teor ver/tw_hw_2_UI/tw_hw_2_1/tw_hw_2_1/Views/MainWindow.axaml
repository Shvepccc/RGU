<!-- Views/MainWindow.axaml -->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EpidemicSimulator.ViewModels"
        xmlns:viewModels="clr-namespace:EpidemicSimulator.ViewModels"
        x:Class="EpidemicSimulator.Views.MainWindow"
        Title="Моделирование распространения болезни"
        Width="1200" Height="800"
        x:DataType="viewModels:MainWindowViewModel">
    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

</Window>